//@version=5
// BTC scoring stack — MAIN (overlay). Add to chart: KRAKEN:BTCUSD (or your BTCUSD pair).
// Companion: btc_scoring_rsi.pine + btc_scoring_macd.pine (separate panes — TV one pane per indicator).
// Horizontal line.new() levels + labels are readable via MCP data_get_pine_lines / labels.
indicator("BTC Scoring — Main (Fib / EMA / Swings)", shorttitle="BTC Scor Main", overlay=true, max_lines_count=100, max_labels_count=100)

int lookback = input.int(50, "Fib: highest/lowest window (bars)", minval=10, group="Fibonacci")
int pivotLegs = input.int(5, "Swing: pivot legs (each side)", minval=2, group="Swings")
color colFib = input.color(color.new(color.teal, 35), "Fib line color", group="Fibonacci")
color colRes = input.color(color.new(color.red, 15), "Resistance (swing high)", group="Swings")
color colSup = input.color(color.new(color.green, 15), "Support (swing low)", group="Swings")

// --- Main chart: EMAs ---
plot(ta.ema(close, 20), "EMA 20", color=color.new(color.orange, 0), linewidth=2)
plot(ta.ema(close, 50), "EMA 50", color=color.new(color.blue, 0), linewidth=2)

// --- Swing pivots (confirmed) ---
float ph = ta.pivothigh(high, pivotLegs, pivotLegs)
float pl = ta.pivotlow(low, pivotLegs, pivotLegs)
var float lastSwingHigh = na
var float lastSwingLow = na
if not na(ph)
    lastSwingHigh := ph
if not na(pl)
    lastSwingLow := pl

// --- Managed drawings (refresh on last bar only) ---
var array<line> fibLines = array.new_line()
var array<label> fibLabels = array.new_label()
var line resLine = na
var line supLine = na
var label resLbl = na
var label supLbl = na

if barstate.islast
    // Clear Fib drawings
    int nf = array.size(fibLines)
    if nf > 0
        for i = 0 to nf - 1
            line.delete(array.get(fibLines, i))
        array.clear(fibLines)
    int nl = array.size(fibLabels)
    if nl > 0
        for i = 0 to nl - 1
            label.delete(array.get(fibLabels, i))
        array.clear(fibLabels)

    float hi = ta.highest(high, lookback)
    float lo = ta.lowest(low, lookback)
    float rng = hi - lo
    int x1 = bar_index - lookback + 1
    int x2 = bar_index

    // Classic retracement from the 50-bar HIGH (same idea as TV Fib tool, impulse low→high):
    // ratio 0 = at high, 1 = at low; e.g. 0.618 → price = high − 61.8% of range (NOT low + 61.8%).
    array<float> ratios = array.from(0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0)
    int nr = array.size(ratios)
    for i = 0 to nr - 1
        float r = array.get(ratios, i)
        float prc = hi - rng * r
        line ln = line.new(x1, prc, x2, prc, extend=extend.right, color=colFib, width=1, style=line.style_solid)
        array.push(fibLines, ln)
        string txt = "Fib " + str.tostring(r)
        label lb = label.new(x2, prc, txt, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, color=color.new(colFib, 80), textcolor=colFib, size=size.small)
        array.push(fibLabels, lb)

    // Swing high / low horizontals (resistance / support)
    if not na(resLine)
        line.delete(resLine)
        resLine := na
    if not na(supLine)
        line.delete(supLine)
        supLine := na
    if not na(resLbl)
        label.delete(resLbl)
        resLbl := na
    if not na(supLbl)
        label.delete(supLbl)
        supLbl := na

    if not na(lastSwingHigh)
        resLine := line.new(x1, lastSwingHigh, x2, lastSwingHigh, extend=extend.right, color=colRes, width=2, style=line.style_solid)
        resLbl := label.new(x2, lastSwingHigh, "Swing High (R)", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, color=color.new(colRes, 80), textcolor=colRes, size=size.small)

    if not na(lastSwingLow)
        supLine := line.new(x1, lastSwingLow, x2, lastSwingLow, extend=extend.right, color=colSup, width=2, style=line.style_solid)
        supLbl := label.new(x2, lastSwingLow, "Swing Low (S)", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, color=color.new(colSup, 80), textcolor=colSup, size=size.small)
